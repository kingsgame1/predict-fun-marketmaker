# ============================================
# ⚡ 激进配置模板 - 收益最大化
# ============================================
# 适用场景：
# - 经验丰富的交易者
# - 熟悉市场机制
# - 能够承受较高风险
# - 追求最大化收益
#
# 特点：
# ⚡ 高收益潜力
# ⚡ 多策略并行
# ⚠️ 风险较高
# ⚠️ 需要密切监控
# ============================================

# ==================== 基础配置 ====================
# 多策略并行
STRATEGY=multi_strategy              # 多策略模式
MAX_POSITION_SIZE=0.2                # 单次最大仓位：20%资金
MAX_TOTAL_POSITION=0.6               # 总最大仓位：60%资金

# ==================== 风险控制 ====================
# 较低的利润要求（更多机会）
MIN_PROFIT_PERCENT=0.5               # 最低利润：0.5%
MIN_PROFIT_USD=5                     # 最低利润：$5

# 较高的滑点容忍
MAX_SLIPPAGE_PERCENT=2.0             # 最大滑点：2%
SLIPPAGE_BUFFER_PERCENT=0.5          # 滑点缓冲：0.5%

# 较低的流动性要求
MIN_LIQUIDITY_USD=1000               # 最低流动性：$1,000
MIN_ORDER_BOOK_DEPTH=500             # 最低订单簿深度：$500

# ==================== 市场选择 ====================
# 包括更多市场
MIN_VOLUME_USD=1000                  # 最低交易量：$1,000
MIN_AGE_HOURS=0.1                    # 市场最少存在：6分钟

# 不过滤市场（参与所有机会）
SKIP_NEW_MARKETS=false               # 不跳过新市场
SKIP_LOW_VOLUME_MARKETS=false        # 不跳过低交易量
SKIP_VOLATILE_MARKETS=false          # 不跳过高波动（反而可能是机会）

# ==================== 执行参数 ====================
# 快速执行
EXECUTION_DELAY_MS=200               # 执行延迟：0.2秒
ORDER_CHECK_INTERVAL_MS=200          # 订单检查间隔：0.2秒
MAX_RETRIES=5                        # 最大重试次数：5次

# 订单设置
ORDER_LIFETIME_MS=10000              # 订单生命周期：10秒
PARTIAL_FILL_ALLOWED=true            # 允许部分成交

# ==================== 市场做市配置 ====================
# 激进做市
MM_ENABLED=true                      # 启用做市
MM_POSITION_SIZE=0.1                 # 做市仓位：10%
MM_TOUCH_BUFFER_BPS=5               # 挂单缓冲：0.05%（紧跟市场价格）

# 第二档挂单策略
MM_QUOTE_SECOND_LAYER=true           # 启用动态定价
MM_TOUCH_BUFFER_FIXED_CENTS=0.01     # 固定偏移：1美分

# 做市风险控制
MM_MAX_POSITIONS=10                  # 最多10个做市仓位
MM_REBALANCE_INTERVAL_MS=1000        # 1秒重新平衡

# ==================== 套利配置 ====================
# 对冲套利
HEDGE_ARB_ENABLED=true
HEDGE_MIN_PROFIT=0.5                 # 最低对冲利润：0.5%
HEDGE_MAX_POSITIONS=10               # 最多同时持仓：10个
HEDGE_REQUIRE_BOTH_SIDES=false      # 不要求两边都有流动性

# 三角套利
TRIANGULAR_ARB_ENABLED=true          # 启用三角套利
TRIANGULAR_MIN_PROFIT=1.0            # 最低利润：1%

# 跨平台套利
CROSS_PLATFORM_ARB_ENABLED=true      # 启用跨平台套利
CROSS_PLATFORM_MIN_PROFIT=0.3        # 最低利润：0.3%

# ==================== 高频配置 ====================
# 激进高频套利
HIGH_FREQ_ENABLED=true               # 启用高频
HIGH_FREQ_MAX_POSITIONS=10           # 最多10个高频仓位
HIGH_FREQ_SCAN_INTERVAL_MS=500       # 扫描间隔：0.5秒

# 高频策略配置
ENABLE_ALL_STRATEGIES=true           # 启用所有7个策略

# ==================== 超级高频套利 ====================
# Super High-Frequency Arbitrage Bot
SUPER_HF_ENABLED=true                # 启用超级高频
SUPER_HF_MODE=aggressive             # 激进模式

# 7大策略全部启用
HF_HIGH_PROBABILITY_BOND=true        # 高概率债券
HF_MEAN_REVERSION=true               # 均值回归
HF_DOMAIN_SPECIALIZATION=true        # 领域专业化
HF_MULTI_RESULT=true                 # 多结果套利
HF_INFORMATION_ARBITRAGE=true        # 信息套利
HF_CROSS_PLATFORM=true               # 跨平台套利
HF_YES_NO_UNDER=true                 # Yes+No<1
HF_DETERMINISTIC_SWEEP=true          # 确定性尾盘

# ==================== Kelly准则 ====================
# Kelly仓位管理
KELLY_ENABLED=true                   # 启用Kelly准则
KELLY_FRACTION=0.5                   # Kelly分数：50%（半Kelly，更激进）
KELLY_MIN_POSITION=0.01              # 最小仓位：1%
KELLY_MAX_POSITION=0.2               # 最大仓位：20%

# Kelly参数
KELLY_WIN_RATE_ESTIMATOR=real_time   # 实时胜率估算
KELLY_CONFIDENCE_INTERVAL=0.95       # 95%置信区间

# ==================== 机会过滤 ====================
# 更宽松的过滤
OPPORTUNITY_FILTER_ENABLED=true
MIN_QUALITY_SCORE=40                 # 最低质量分数：40/100（较宽松）
RELIABILITY_THRESHOLD=0.6            # 可靠性阈值：60%

# 不过滤低利润机会
FILTER_LOW_OPPORTUNITIES=false       # 不过滤

# ==================== 平台配置 ====================
# 多平台同时启用
PROBABLE_ENABLED=true
PROBABLE_MIN_CONFIDENCE=0.7          # 最低确定性：70%

PREDICT_ENABLED=true
PREDICT_MIN_CONFIDENCE=0.7           # 最低确定性：70%

POLYMARKET_ENABLED=false             # 如果配置了也可以启用

# ==================== 策略特定配置 ====================
# 确定性尾盘套利 - 激进版
DETERMINISTIC_SWEEP_ENABLED=true     # 启用
DETERMINISTIC_MIN_CONFIDENCE=0.9     # 最低确定性：90%
DETERMINISTIC_REQUIRE_VERIFIED=false # 不强制要求验证数据

# 循环交易 - 激进参数
LOOP_TRADING_ENABLED=true
LOOP_COUNT=50                        # 循环50次
LOOP_INTERVAL_MS=500                 # 间隔：0.5秒

# 对冲套利 - 激进参数
HEDGE_ARB_ENABLED=true
HEDGE_ALL_OPTIONS=true               # 对冲所有选项
HEDGE_MIN_PROFIT=0.01                # 最低利润：1%

# ==================== 通知配置 ====================
# 全面的通知
NOTIFICATIONS_ENABLED=true
NOTIFY_ON_EXECUTION=true             # 执行时通知
NOTIFY_ON_PROFIT=true                # 盈利时通知
NOTIFY_ON_ERROR=true                 # 错误时通知
NOTIFY_ON_HIGH_FREQ=true             # 高频时通知
NOTIFY_ON_LARGE_POSITION=true        # 大仓位时通知（>15%）

# ==================== 监控配置 ====================
# 密集监控
MONITOR_INTERVAL_MS=1000             # 监控间隔：1秒
LOG_LEVEL=debug                      # 日志级别：debug
SAVE_EXECUTION_STATS=true            # 保存执行统计
EXPORT_TO_CSV=true                   # 导出CSV

# ==================== 资金管理 ====================
# 动态仓位
DYNAMIC_POSITION_SIZING=true         # 动态调整仓位
BASE_POSITION_SIZE=0.1               # 基础仓位：10%
MAX_POSITION_MULTIPLIER=2.0          # 最大仓位倍数：2x

# 风险调整
RISK_ADJUSTED_SIZING=true            # 风险调整仓位
VOLATILITY_ADJUSTMENT=true           # 波动率调整

# ==================== 高级策略 ====================
# 做市增强
MM_ENABLE_INVENTORY_MANAGEMENT=true  # 库存管理
MM_ENABLE_DELTA_HEDGING=true         # Delta对冲
MM_ENABLE_SKEW_ADJUSTMENT=true       # 偏度调整

# 套利增强
ARB_ENABLE_PARALLEL_EXECUTION=true   # 并行执行
ARB_ENABLE_MERCURY_ORDER=false       # Mercury订单（极速）
ARB_ENABLE_FLASH_ORDERS=false        # Flash订单（如果支持）

# ==================== 统计和分析 ====================
# 实时统计
REAL_TIME_STATS=true                 # 实时统计
PERFORMANCE_TRACKING=true            # 绩效追踪
DAILY_REPORT=true                    # 每日报告

# ==================== 安全限制（较宽松） ====================
# 每日限制
DAILY_MAX_EXECUTIONS=200             # 每日最多执行：200次
DAILY_MAX_LOSS_USD=200               # 每日最大亏损：$200
DAILY_STOP_ON_LOSS=true              # 达到亏损限制时停止

# 自动停止
AUTO_STOP_ON_ERROR=false             # 不自动停止
AUTO_STOP_ON_SLIPPAGE=false          # 不因滑点停止
AUTO_STOP_ON_DRAIN=true              # 资金耗尽时停止

# ==================== 保证金和资金 ====================
MIN_BALANCE_USD=200                  # 最低余额：$200
RESERVE_BALANCE_USD=50               # 保留余额：$50
MAX_BALANCE_USAGE=0.95               # 最大使用：95%

# 允许杠杆（如果平台支持）
ALLOW_LEVERAGE=false                 # 默认不使用杠杆（安全考虑）
MAX_LEVERAGE=1.5                     # 最大杠杆：1.5x

# ==================== 时间控制 ====================
# 全天候交易
TRADING_HOUR_START=0                 # 开始：0点
TRADING_HOUR_END=24                  # 结束：24点
SKIP_WEEKENDS=false                  # 不过滤周末

# 高峰期加强（如果检测到高波动）
INCREASE_ACTIVITY_IN_VOLATILITY=true # 波动时增加活动

# ==================== 高级设置（性能优化） ====================
# 网络优化
NETWORK_TIMEOUT_MS=5000              # 网络超时：5秒
MAX_NETWORK_RETRIES=5                # 最大重试：5次
CONCURRENT_REQUESTS=10               # 并发请求：10个

# WebSocket优化
WEBSOCKET_RECONNECT_AUTO=true        # 自动重连
WEBSOCKET_PING_INTERVAL=30000        # Ping间隔：30秒

# 缓存
ENABLE_ORDER_BOOK_CACHE=true         # 订单簿缓存
CACHE_TTL_MS=500                     # 缓存有效期：0.5秒

# ==================== API和限流 ====================
API_RATE_LIMIT=50                    # API限制：50次/秒
API_BURST_LIMIT=200                  # 突发限制：200次

# ==================== 模拟模式 ====================
# 激进模式默认实盘，但可以先用模拟测试
SIMULATION_MODE=false                # 实盘模式
SIMULATION_SLIPPAGE=0.5              # 模拟滑点：0.5%
SIMULATION_FILL_RATE=0.9             # 模拟成交率：90%

# 如果要测试，改为：
# SIMULATION_MODE=true
# SIMULATION_DURATION_HOURS=24       # 模拟24小时

# ==================== 监控和告警 ====================
# 实时监控面板
ENABLE_DASHBOARD=true                # 启用仪表板
DASHBOARD_PORT=3000                  # 仪表板端口

# 告警
ALERT_ON_LARGE_LOSS=true             # 大额亏损告警（>$100）
ALERT_ON_UNUSUAL_ACTIVITY=true       # 异常活动告警
ALERT_ON_CONNECTION_LOSS=true        # 连接丢失告警

# ==================== 实验性功能 ====================
# 机器学习预测（如果实现）
ML_PREDICTION_ENABLED=false          # ML预测（实验性）
ML_MODEL_PATH=./models               # 模型路径

# 社交媒体分析（如果实现）
SOCIAL_SENTIMENT_ENABLED=false       # 社交情绪分析
TWITTER_API_KEY=                     # Twitter API密钥
REDDIT_API_KEY=                      # Reddit API密钥

# ============================================
# ⚠️ 重要警告：
# 1. 激进模式风险较高，可能导致较大亏损
# 2. 请确保完全理解每个参数的含义
# 3. 建议先在模拟模式下测试至少1周
# 4. 监控资金使用，确保有足够储备
# 5. 设置合理的止损和日常限制
# 6. 密切关注市场变化和异常情况
#
# 💡 推荐流程：
# 1. 模拟模式测试1-2周
# 2. 检查绩效指标（夏普比率、最大回撤等）
# 3. 小资金实盘测试（$100-200）
# 4. 逐步增加到目标资金
# 5. 持续监控和调整参数
# ============================================
