# ============================================
# 🔒 保守配置模板 - 安全第一
# ============================================
# 适用场景：
# - 新手用户
# - 测试阶段
# - 不确定的市场环境
# - 希望最小化风险
#
# 特点：
# ✅ 高成功率（>90%）
# ✅ 低风险
# ✅ 稳定收益
# ⚠️ 收益相对较低
# ============================================

# ==================== 基础配置 ====================
# 策略选择
STRATEGY=hedge_arb_only              # 只做对冲套利（最安全）
MAX_POSITION_SIZE=0.05               # 单次最大仓位：5%资金
MAX_TOTAL_POSITION=0.15              # 总最大仓位：15%资金

# ==================== 风险控制 ====================
# 最小利润要求
MIN_PROFIT_PERCENT=2.0               # 最低利润：2%
MIN_PROFIT_USD=10                    # 最低利润：$10

# 滑点控制
MAX_SLIPPAGE_PERCENT=0.5             # 最大滑点：0.5%
SLIPPAGE_BUFFER_PERCENT=0.2          # 滑点缓冲：0.2%

# 流动性要求
MIN_LIQUIDITY_USD=5000               # 最低流动性：$5000
MIN_ORDER_BOOK_DEPTH=2000            # 最低订单簿深度：$2000

# ==================== 市场选择 ====================
# 只交易高质量市场
MIN_VOLUME_USD=10000                 # 最低交易量：$10,000
MIN_AGE_HOURS=1                      # 市场最少存在：1小时

# 过滤高风险市场
SKIP_NEW_MARKETS=true                # 跳过新市场
SKIP_LOW_VOLUME_MARKETS=true         # 跳过低交易量市场
SKIP_VOLATILE_MARKETS=true           # 跳过高波动市场

# ==================== 执行参数 ====================
# 保守执行
EXECUTION_DELAY_MS=2000              # 执行延迟：2秒
ORDER_CHECK_INTERVAL_MS=1000         # 订单检查间隔：1秒
MAX_RETRIES=2                        # 最大重试次数：2次

# 订单设置
ORDER_LIFETIME_MS=30000              # 订单生命周期：30秒
PARTIAL_FILL_ALLOWED=false           # 不允许部分成交

# ==================== 市场做市配置 ====================
# 如果启用做市策略
MM_ENABLED=false                     # 保守模式下默认不做市
MM_POSITION_SIZE=0.02                # 做市仓位：2%
MM_TOUCH_BUFFER_BPS=25              # 挂单缓冲：0.25%（安全距离）

# ==================== 套利配置 ====================
# 对冲套利（保守模式默认）
HEDGE_ARB_ENABLED=true
HEDGE_MIN_PROFIT=2.0                 # 最低对冲利润：2%
HEDGE_MAX_POSITIONS=3                # 最多同时持仓：3个
HEDGE_REQUIRE_BOTH_SIDES=true       # 要求两边都有流动性

# ==================== 高频配置 ====================
# 高频套利 - 保守设置
HIGH_FREQ_ENABLED=false              # 保守模式不启用高频
HIGH_FREQ_MAX_POSITIONS=1            # 最多1个高频仓位

# ==================== 通知配置 ====================
# 实时通知
NOTIFICATIONS_ENABLED=true
NOTIFY_ON_EXECUTION=true             # 执行时通知
NOTIFY_ON_PROFIT=true                # 盈利时通知
NOTIFY_ON_ERROR=true                 # 错误时通知

# ==================== 监控配置 ====================
# 实时监控
MONITOR_INTERVAL_MS=5000             # 监控间隔：5秒
LOG_LEVEL=info                       # 日志级别
SAVE_EXECUTION_STATS=true            # 保存执行统计

# ==================== 资金管理 ====================
# Kelly准则 - 保守版本
KELLY_ENABLED=false                  # 保守模式不使用Kelly
KELLY_FRACTION=0.25                  # Kelly分数：25%（极保守）

# 固定仓位管理
FIXED_POSITION_MODE=true             # 使用固定仓位
POSITION_SIZE_PERCENT=5              # 固定5%仓位

# ==================== 机会过滤 ====================
# 质量过滤
OPPORTUNITY_FILTER_ENABLED=true
MIN_QUALITY_SCORE=70                 # 最低质量分数：70/100
RELIABILITY_THRESHOLD=0.9            # 可靠性阈值：90%

# ==================== 平台配置 ====================
# Probable平台
PROBABLE_ENABLED=true
PROBABLE_MIN_CONFIDENCE=0.85         # 最低确定性：85%

# Predict平台
PREDICT_ENABLED=false                # 保守模式只用一个平台
PREDICT_MIN_CONFIDENCE=0.9           # 如果启用，最低90%

# ==================== 策略特定配置 ====================
# 确定性尾盘套利（如果启用）
DETERMINISTIC_SWEEP_ENABLED=false   # 保守模式不启用
DETERMINISTIC_MIN_CONFIDENCE=0.98    # 最低确定性：98%
DETERMINISTIC_REQUIRE_VERIFIED=true  # 要求验证数据

# ==================== 日志和调试 ====================
DEBUG_LOGGING=false                  # 关闭调试日志
PERFORMANCE_LOGGING=true             # 启用性能日志
EXPORT_EXECUTION_CSV=true            # 导出执行CSV

# ==================== 安全限制 ====================
# 每日限制
DAILY_MAX_EXECUTIONS=20              # 每日最多执行：20次
DAILY_MAX_LOSS_USD=50                # 每日最大亏损：$50
DAILY_STOP_ON_LOSS=true              # 达到亏损限制时停止

# 自动停止
AUTO_STOP_ON_ERROR=false             # 不自动停止（手动控制）
AUTO_STOP_ON_SLIPPAGE=true           # 滑点过大时停止
MAX_SLIPPAGE_STOP_THRESHOLD=1.0     # 停止阈值：1%

# ==================== 保证金和资金安全 ====================
MIN_BALANCE_USD=500                  # 最低余额要求：$500
RESERVE_BALANCE_USD=100              # 保留余额：$100
MAX_BALANCE_USAGE=0.8                # 最大使用余额：80%

# ==================== 时间控制 ====================
# 交易时间窗口
TRADING_HOUR_START=0                 # 开始时间：0点
TRADING_HOUR_END=24                  # 结束时间：24点（全天）
SKIP_WEEKENDS=false                  # 不过滤周末（加密市场7x24）

# ==================== 高级设置（请谨慎修改） ====================
# Gas费用（Layer 2）
MAX_GAS_PRICE_GWEI=50                # 最大Gas价格：50 Gwei
GAS_BUFFER_PERCENT=20                # Gas缓冲：20%

# 网络设置
NETWORK_TIMEOUT_MS=10000             # 网络超时：10秒
MAX_NETWORK_RETRIES=3                # 最大网络重试：3次

# API限流
API_RATE_LIMIT=10                    # API调用限制：10次/秒
API_BURST_LIMIT=50                   # API突发限制：50次

# ==================== 模拟模式 ====================
# 模拟交易（测试用）
SIMULATION_MODE=false                # 实盘模式
SIMULATION_SLIPPAGE=0.3              # 模拟滑点：0.3%
SIMULATION_FILL_RATE=0.95            # 模拟成交率：95%

# ============================================
# 💡 使用建议：
# 1. 先在模拟模式下测试（SIMULATION_MODE=true）
# 2. 小资金测试（MIN_PROFIT_USD可以设低一点）
# 3. 监控执行统计，查看日志
# 4. 确认稳定后再逐步提高参数
# 5. 始终保留足够的储备金（RESERVE_BALANCE_USD）
# ============================================
