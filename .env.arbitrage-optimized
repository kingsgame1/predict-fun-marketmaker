# ==========================================
# Predict.fun 套利优化配置
# ==========================================
# 快速改进配置 - 2025-02-22
# ==========================================

# ==================== 站内套利优化 ====================

# 更严格的利润要求
ARB_MIN_PROFIT=0.02                 # 最小利润 2%（提高到 1%）

# 更严格的深度要求
ARB_MIN_DEPTH=100                   # 最小深度 100 股

# 最大滑点限制
ARB_MAX_SLIPPAGE=0.005              # 0.5% 最大滑点

# 启用预检（强烈推荐）
ARB_PREFLIGHT_ENABLED=true           # 启用预检
ARB_WS_REALTIME=true                 # 实时 WebSocket 扫描

# ==================== 跨平台套利优化 ====================

# 提高相似度要求（减少假阳性）
CROSS_PLATFORM_MIN_SIMILARITY=0.85  # 0.78 → 0.85

# 更保守的利润要求
CROSS_PLATFORM_MIN_PROFIT=0.02     # 1% → 2%

# 降低单次交易量（减少风险）
CROSS_PLATFORM_MAX_SHARES=100       # 200 → 100

# 更严格的 VWAP 检查
CROSS_PLATFORM_MAX_VWAP_DEVIATION_BPS=30   # 添加 VWAP 偏差检查

# 启用执行预检
CROSS_PLATFORM_EXECUTION_VWAP_CHECK=true    # 启用 VWAP 检查

# 价格漂移检查
CROSS_PLATFORM_PRICE_DRIFT_BPS=30          # 价格漂移检查 30 bps

# 提交前重检
CROSS_PLATFORM_PRE_SUBMIT_RECHECK_MS=1000    # 提交前 1 秒重检
CROSS_PLATFORM_PRE_SUBMIT_GLOBAL=true         # 全局预检

# 自适应仓位大小
CROSS_PLATFORM_ADAPTIVE_SIZE=true             # 启用自适应仓位

# 最小名义价值
CROSS_PLATFORM_MIN_NOTIONAL_USD=50           # 最小名义价值 $50

# ==================== WebSocket 实时扫描优化 ====================

# 启用实时扫描
CROSS_PLATFORM_WS_REALTIME=true                  # 启用实时扫描
CROSS_PLATFORM_WS_REALTIME_INTERVAL_MS=500    # 500ms 扫描间隔
CROSS_PLATFORM_WS_REALTIME_MAX_BATCH=50         # 每批最多 50 个市场

# 启用回退模式
CROSS_PLATFORM_WS_REALTIME_FALLBACK_ENABLED=true
CROSS_PLATFORM_WS_REALTIME_FALLBACK_INTERVAL_MS=3000
CROSS_PLATFORM_WS_REALTIME_FALLBACK_MAX_MARKETS=80

# ==================== 风险控制优化 ====================

# 最大执行数（批量执行时限制）
CROSS_PLATFORM_MAX_MATCHES=15           # 20 → 15

# 转账成本估计（跨平台）
CROSS_PLATFORM_TRANSFER_COST=0.002    # 0.2%

# 滑点容忍度
CROSS_PLATFORM_SLIPPAGE_BPS=250       # 250 bps (2.5%)

# 深度检查
CROSS_PLATFORM_DEPTH_LEVELS=10        # 使用 10 层深度

# ==================== 高级功能 ====================

# 价值错配套利
USE_VALUE_SIGNAL=true                 # 启用价值信号
VALUE_SIGNAL_WEIGHT=0.35             # 价值权重 35%
VALUE_CONFIDENCE_MIN=0.7             # 最小置信度 70%

# ==================== 做市商与套利协调 ====================

# 做市商积分优化（同时运行做市商）
MM_POINTS_PRIORITIZE=true            # 优先积分市场
MM_POINTS_OPTIMIZATION=true          # 启用积分优化
MM_POINTS_V2_OPTIMIZER=true          # 启用 V2 优化

# ==================== 日志和调试 ====================

# 套利日志详细程度
ARB_LOG_LEVEL=INFO                   # 日志级别

# 启用详细日志
DEBUG_ARB_SCANNING=true             # 扫描调试
DEBUG_ARB_EXECUTION=true            # 执行调试

# ==================== 性能优化 ====================

# 并发控制
MAX_CONCURRENT_ARBITRAGES=3         # 最多 3 个并发套利

# 缓存配置
CACHE_ORDERBOOK_TTL=1000             # 订单簿缓存 1 秒
CACHE_MARKET_DATA_TTL=5000          # 市场数据缓存 5 秒

# ==================== 监控和统计 ====================

# 启用统计收集
ARBITRAGE_STATS_ENABLED=true        # 启用统计收集
ARBITRAGE_STATS_INTERVAL_MS=60000   # 每 1 分钟输出统计

# ==================== 警告和通知 ====================

# 成功率警告阈值
WARN_SUCCESS_RATE_BELOW=0.7         # 成功率 < 70% 时警告
WARN_FAILURE_RATE_HIGH=0.2          # 失败率 > 20% 时警告

# ==================== 开发/调试模式 ====================

# 模拟模式（测试时使用）
ENABLE_TRADING=false                 # false=模拟, true=实盘

# 自动确认（测试时可启用）
AUTO_CONFIRM=false                   # 自动确认订单

# ==================== 说明 ====================

# 保守配置特点：
# - 更高的利润要求（2%）
# - 更严格的风险控制
# - 更小的仓位大小
# - 更多的预检检查
# - 适合新手和低风险偏好用户

# 平衡配置特点：
# - 平衡的利润要求和风险
# - 适度的仓位大小
# - 基本的风险控制
# - 适合有经验的用户

# 激进配置特点：
# - 较低的利润要求（1%）
# - 较大的仓位大小
# - 更多的执行机会
# - 较高的风险
# - 适合高风险高回报用户

# ==================== 推荐的配置调整流程 ====================

# 第 1 步：使用模拟模式测试
# ENABLE_TRADING=false

# 第 2 步：从小仓位开始
# CROSS_PLATFORM_MAX_SHARES=20

# 第 3 步：观察效果，逐步增加
# CROSS_PLATFORM_MAX_SHARES=50
# CROSS_PLATFORM_MAX_SHARES=100

# 第 4 步：启用实盘模式
# ENABLE_TRADING=true

# ==================== 监控指标 ====================

# 关键指标：
# - 成功率 > 80%
# - 平均利润率 > 1.5%
# - 失败率 < 10%
# - 最大回撤 < 5%

# 警告信号：
# - 成功率 < 70% → 参数太激进
# - 失败率 > 20% → 预检太松
# - 平均利润率 < 1% → 机会质量低

# ==================== 定期维护 ====================

# 每小时：查看日志
# 每天：检查统计
# 每周：调整参数
# 每月：回顾优化

