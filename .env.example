# ============================================
# Predict.fun Market Maker - 默认配置模板
# ============================================
# 📝 说明：
# - 带 🔴 = 必须填写（系统无法运行）
# - 带 🟡 = 建议填写（影响功能）
# - 带 🟢 = 可选填写（增强功能）
# - 其余为默认值（建议保持）
# ============================================

# ==================== 🔴 必填配置（必需） ====================

# API配置 - Predict.fun平台
API_BASE_URL=https://api.predict.fun
API_KEY=🔴_你的API密钥
JWT_TOKEN=🔴_你的JWT令牌

# 区块链RPC配置（BNB Chain）
RPC_URL=https://bsc-dataseed.binance.org
# 备用节点（如果主节点不可用）：
# RPC_URL=https://bsc-dataseed1.binance.org
# RPC_URL=https://bsc-dataseed2.binance.org

# 钱包配置
PRIVATE_KEY=🔴_你的私钥（不带0x前缀，64位十六进制）
PREDICT_ACCOUNT_ADDRESS=🔴_你的Predict账户地址（0x开头的42位地址）

# ==================== 🔴 激活码服务器配置（必需） ====================
# ⚠️ 重要：在线验证是必需的，否则激活码系统可以被破解！

# 激活验证服务器URL
# 替换为您的服务器地址，例如：https://api.yourdomain.com
ACTIVATION_SERVER_URL=http://localhost:3000

# 是否启用在线验证（默认true，生产环境必须保持true）
# ⚠️ 设为false将禁用在线验证，系统不安全！仅用于开发测试
ENABLE_ONLINE_VALIDATION=true

# 服务器公钥（用于验证激活码签名）
# 从服务器复制 keys/public.pem 的内容，多行字符串需要用引号包围
# ACTIVATION_SERVER_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----
# MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
# ...
# -----END PUBLIC KEY-----"

# ==================== 🟡 建议配置（重要） ====================

# 策略选择
STRATEGY=arbitrage

# 交易参数（建议根据资金情况调整）
ORDER_SIZE=10                    # 单笔订单大小（美元）
MAX_POSITION=100                 # 单个市场最大持仓（美元）
MAX_DAILY_LOSS=200              # 每日最大亏损（美元）

# 做市配置（如果启用做市策略）
MM_ENABLED=false                 # 默认不启用做市（新手建议先不启用）
MM_POSITION_SIZE=0.05           # 做市仓位比例（5%）

# 套利配置
ENABLE_ARBITRAGE=true           # 启用套利
MIN_PROFIT_PERCENT=2.0           # 最低利润要求（2%）
MIN_LIQUIDITY_USD=5000           # 最低流动性要求（5000美元）

# ==================== 🟢 可选配置（增强功能） ====================

# 日志配置
LOG_LEVEL=info                  # 日志级别：debug, info, warn, error, silent
SAVE_EXECUTION_STATS=true      # 保存执行统计
EXPORT_TO_CSV=true               # 导出CSV报告

# 告警通知（可选）
ENABLE_NOTIFICATIONS=false     # 启用通知（默认关闭）
NOTIFICATION_TYPE=console       # 通知类型：console, telegram, email
# TELEGRAM_BOT_TOKEN=           # Telegram机器人Token（如需启用）
# TELEGRAM_CHAT_ID=             # Telegram Chat ID（如需启用）

# 模拟模式（测试时使用）
SIMULATION_MODE=false            # false=实盘, true=模拟

# ==================== 高级配置（建议保持默认） ====================

# 价差设置
SPREAD=0.02                     # 基础价差（2%）
MIN_SPREAD=0.01                  # 最小价差（1%）
MAX_SPREAD=0.08                  # 最大价差（8%）

# 订单管理
CANCEL_THRESHOLD=0.05           # 价格变动取消阈值（5%）
REPRICE_THRESHOLD=0.003         # 重新报价阈值（0.3%）
MIN_ORDER_INTERVAL_MS=3000      # 最小订单间隔（3秒）
MAX_ORDERS_PER_MARKET=2         # 每个市场最大订单数

# 反填充机制（防止成交）
ANTI_FILL_BPS=0.002             # 反填充基点（0.2%）
NEAR_TOUCH_BPS=0.0015           # 接近触摸基点（0.15%）
COOLDOWN_AFTER_CANCEL_MS=4000   # 取消后冷却时间（4秒）

# 波动率控制
VOLATILITY_PAUSE_BPS=0.01        # 暂停波动率基点（1%）
VOLATILITY_LOOKBACK_MS=10000    # 波动率回看时间（10秒）
PAUSE_AFTER_VOLATILITY_MS=8000 # 波动后暂停时间（8秒）

# ==================== 配置验证说明 ====================

# 系统启动时会自动验证配置：
# ✅ API密钥格式检查
# ✅ 钱包私钥格式检查（64位十六进制）
# ✅ 账户地址格式检查（0x + 40位十六进制）
# ✅ 参数合理性检查（价差、仓位等）
# ✅ 风险控制检查（止损、限额等）

# 如果验证失败，系统会显示详细错误信息并退出。

# ==================== 快速开始指南 ====================

# 1. 复制此模板为.env文件
# cp .env.example .env

# 2. 填写必填项（🔴标记）
# vim .env
# 填写：API_KEY, JWT_TOKEN, PRIVATE_KEY, PREDICT_ACCOUNT_ADDRESS

# 3. 测试配置（推荐先模拟测试）
# SIMULATION_MODE=true npm start

# 4. 查看运行日志，确认一切正常

# 5. 切换到实盘
# vim .env  # 改为 SIMULATION_MODE=false
# npm start

# ==================== 保守模式建议（新手推荐） ====================

# 如果你是新手，建议使用以下保守设置：

# STRATEGY=arbitrage            # 只做套利，不做市
# MM_ENABLED=false               # 不启用做市
# ORDER_SIZE=5                  # 小单开始
# MAX_POSITION=50               # 小仓位
# MAX_DAILY_LOSS=50             # 低止损
# MIN_PROFIT_PERCENT=3.0        # 高利润要求
# SIMULATION_MODE=true          # 先模拟测试

# ==================== 激进模式建议（经验用户） ====================

# 如果你有经验，可以使用以下激进设置：

# STRATEGY=multi_strategy        # 多策略并行
# MM_ENABLED=true                # 启用做市
# MM_POSITION_SIZE=0.1           # 做市仓位10%
# ORDER_SIZE=20                 # 大单
# MAX_POSITION=200              # 大仓位
# MAX_DAILY_LOSS=500            # 高止损
# MIN_PROFIT_PERCENT=1.0        # 低利润要求，更多机会
# ENABLE_NOTIFICATIONS=true      # 启用通知

# ==================== 配置优化建议 ====================

# 根据你的资金规模调整配置：

# 小资金（<$1000）
# ORDER_SIZE=5
# MAX_POSITION=50
# MAX_DAILY_LOSS=50
# MIN_PROFIT_PERCENT=3.0

# 中资金（$1000-$5000）
# ORDER_SIZE=10
# MAX_POSITION=100
# MAX_DAILY_LOSS=200
# MIN_PROFIT_PERCENT=2.0

# 大资金（>$5000）
# ORDER_SIZE=20
# MAX_POSITION=200
# MAX_DAILY_LOSS=500
# MIN_PROFIT_PERCENT=1.5

# ==================== 安全提醒 ====================

# ⚠️ 重要安全提示：
# 1. 永远不要将私钥提交到Git仓库
# 2. 定期更换API密钥
# 3. 使用强密码和双重认证
# 4. 定期查看交易记录
# 5. 设置合理的止损和限额
# 6. 不要使用全部资金进行交易

# ==================== 版本信息 ====================

# 版本: 3.1.0
# 更新: 2026-02-22
# 兼容性: Predict.fun, Probable.markets

# ==================== 祝您交易顺利！🚀 ====================
