# ============================================
# Predict.fun Market Maker - 简化版配置
# ============================================
# 📝 说明：
# - 本版本仅包含做市商挂单功能（完全免费）
# - 适合新手赚取积分使用
# - 无需激活码，开箱即用
# ============================================

# ==================== 🔴 必填配置（必需） ====================

# API配置
API_BASE_URL=https://api.predict.fun
API_KEY=🔴_你的API密钥
JWT_TOKEN=🔴_你的JWT令牌

# 钱包配置
PRIVATE_KEY=🔴_你的私钥（不带0x前缀，64位十六进制）
PREDICT_ACCOUNT_ADDRESS=🔴_你的账户地址（0x开头的42位地址）

# 区块链RPC配置（BNB Chain）
RPC_URL=https://bsc-dataseed.binance.org

# ==================== 🟡 建议配置（重要） ====================

# 做市商配置
MM_ENABLED=true                    # 启用做市商
MM_POSITION_SIZE=0.05              # 做市仓位比例（5%）
ORDER_SIZE=10                      # 订单大小（美元）
MAX_POSITION=100                   # 最大持仓（美元）
MAX_DAILY_LOSS=200                 # 每日最大亏损（美元）

# 价差配置
SPREAD=0.02                        # 基础价差（2%）
MIN_SPREAD=0.01                    # 最小价差（1%）
MAX_SPREAD=0.08                    # 最大价差（8%）

# ==================== 🟢 可选配置（增强功能） ====================

# 日志配置
LOG_LEVEL=info                     # 日志级别：debug, info, warn, error

# 模拟模式（测试时使用）
SIMULATION_MODE=false              # false=实盘, true=模拟

# ==================== 📖 使用说明 ====================

# 1. 复制配置文件
# cp .env.example .env

# 2. 填写必填项（API_KEY, JWT_TOKEN, PRIVATE_KEY, PREDICT_ACCOUNT_ADDRESS）

# 3. 安装依赖并启动
# npm install
# npm start

# ==================== 🎯 功能说明 ====================

本版本提供：
- ✅ 自动做市商挂单
- ✅ 智能报价
- ✅ 风险控制
- ✅ WebSocket实时数据
- ✅ 积分赚取优化

本版本不包含：
- ❌ 套利机器人
- ❌ 高频交易
- ❌ 跨平台套利

# ==================== 💡 新手推荐配置 ====================

# 小资金测试
MM_ENABLED=true
ORDER_SIZE=5
MAX_POSITION=50
MAX_DAILY_LOSS=50
SPREAD=0.02
SIMULATION_MODE=true  # 先模拟测试

# ==================== ⚠️ 重要提示 ====================

# 1. 永远不要将私钥提交到Git仓库
# 2. 建议先使用 SIMULATION_MODE=true 测试
# 3. 设置合理的止损和限额
# 4. 定期查看交易记录
# 5. 不要使用全部资金进行交易

# ==================== 版本信息 ====================

# 版本: 1.0.0 (简化版)
# 更新: 2025-02-24
# 平台: Predict.fun
# 网络: BSC (BNB Smart Chain)

# ==================== 祝您交易顺利！🚀 ====================
