# MM_VENUE=polymarket
# （会自动使用 Polymarket API，无需额外的 API_KEY 和 JWT_TOKEN）

# ==================== 📊 市场推荐工具配置（新增） ====================

# 交互式市场选择配置
INTERACTIVE_MARKET_SELECTION=false    # 启动时是否启用交互式市场选择
MARKET_RECOMMEND_TOP_N=20             # 推荐显示前 N 个市场
MARKET_RECOMMEND_MIN_SCORE=0          # 最低评分要求（0-100）
MARKET_RECOMMEND_MIN_LIQUIDITY=0      # 最低流动性要求（USD）
MARKET_RECOMMEND_POINTS_ONLY=false    # 是否只显示积分激活市场

# 默认订单配置
DEFAULT_ORDER_CAPITAL_USD=500         # 默认每个市场投入资金（USD）
DEFAULT_ORDER_SIZE_USD=25             # 黢单笔订单大小（USD）
DEFAULT_MAX_POSITION_USD=100          # 默认最大持仓（USD）

# 市场推荐工具使用说明：
# 运行命令：npm run market:recommend
# 
# 功能：
# - 自动获取并分析所有市场
# - 计算每个市场的 1% 流动性
# - 按评分排序显示推荐市场
# - 交互式选择市场和配置参数
# - 自动保存配置到 .env.market_selection
#
# 推荐流程：
# 1. 查看市场推荐表格
# 2. 输入序号查看市场详情
# 3. 配置订单参数（资金、股数、价差等）
# 4. 选择市场并保存配置
# 5. 启动做市商应用配置

# ==================== 统一做市商策略（最新最完善的策略） ====================
# 这是整合了所有优点的策略，包含异步对冲、双轨并行、动态偏移等高级功能

# 启用统一做市商策略（强烈推荐！）
UNIFIED_MARKET_MAKER_ENABLED=true                        # 启用统一做市商策略

# 核心功能配置
UNIFIED_MARKET_MAKER_TOLERANCE=0.05                    # 对冲偏差容忍度 (0.05 = 5%)
UNIFIED_MARKET_MAKER_MIN_SIZE=10                          # 最小对冲数量 (shares)
UNIFIED_MARKET_MAKER_MAX_SIZE=500                         # 最大对冲数量 (shares)
UNIFIED_MARKET_MAKER_HEDGE_SLIPPAGE_BPS=250             # 对冲滑点 (2.5%)
UNIFIED_MARKET_MAKER_BUY_SPREAD_BPS=150                  # Buy 单价差 (1.5%)
UNIFIED_MARKET_MAKER_SELL_SPREAD_BPS=150                 # Sell 单价差 (1.5%)

# 高级功能（可选）
UNIFIED_MARKET_MAKER_ASYNC_HEDGING=true                # 启用异步对冲（不撤单直接对冲）
UNIFIED_MARKET_MAKER_DUAL_TRACK_MODE=true              # 启用双轨并行模式（YES+NO同时挂单）
UNIFIED_MARKET_MAKER_DYNAMIC_OFFSET_MODE=true           # 启用动态偏移模式（第二档挂单）
UNIFIED_MARKET_MAKER_MONITOR_TIER_ONE=true               # 启用第一档监控（自动撤单重挂）

# 策略说明：
# - 异步对冲：不撤销现有订单，直接执行对冲，减少滑点和机会成本
# - 双轨并行：YES 和 NO 市场同时挂单，提高资金利用率
# - 动态偏移：在第二档挂单，避免成为第一档，减少被成交概率
# - 第一档监控：实时监控是否成为第一档，自动撤单重挂
#
# 推荐配置：全部启用以获得最佳性能
