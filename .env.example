# ============================================
# Predict.fun Market Maker - 简化版配置
# ============================================
# 📝 说明：
# - 本版本仅包含做市商挂单功能（完全免费）
# - 适合新手赚取积分使用
# - 无需激活码，开箱即用
# ============================================

# ==================== 🔴 必填配置（必需） ====================

# API配置
API_BASE_URL=https://api.predict.fun
API_KEY=🔴_你的API密钥
JWT_TOKEN=🔴_你的JWT令牌

# 钱包配置
PRIVATE_KEY=🔴_你的私钥（不带0x前缀，64位十六进制）
PREDICT_ACCOUNT_ADDRESS=🔴_你的账户地址（0x开头的42位地址）

# 区块链RPC配置（BNB Chain）
RPC_URL=https://bsc-dataseed.binance.org

# ==================== 🟡 建议配置（重要） ====================

# 平台选择（predict 或 polymarket）
MM_VENUE=predict                    # predict=Predict.fun, polymarket=Polymarket

# 做市商配置
MM_ENABLED=true                    # 启用做市商
MM_POSITION_SIZE=0.05              # 做市仓位比例（5%）
ORDER_SIZE=25                      # 订单大小（美元）⚠️ 重要：至少$20确保满足min_shares
MAX_POSITION=100                   # 最大持仓（美元）
MAX_DAILY_LOSS=200                 # 每日最大亏损（美元）

# 价差配置（Predict积分要求：≤6¢）
SPREAD=0.015                       # 基础价差（1.5%）- 降低以提高竞争力
MIN_SPREAD=0.008                   # 最小价差（0.8%）
MAX_SPREAD=0.055                   # 最大价差（5.5%）- 必须<6¢以满足积分要求

# ==================== 🟢 可选配置（增强功能） ====================

# 积分优化配置（重要！）
MM_POINTS_MIN_SHARES=100           # 最小订单股数（Predict积分要求）
MM_POINTS_MAX_SPREAD_CENTS=6       # 最大价差（美分，Predict积分要求）
MM_POINTS_OPTIMIZATION=true        # 启用积分优化器
MM_POINTS_V2_OPTIMIZER=true        # 启用V2优化器（更先进）
MM_POINTS_PRIORITIZE=true          # 优先积分市场
MM_POINTS_MIN_ONLY=true            # 只做满足积分要求的市场（推荐）
MM_POINTS_MIN_MULTIPLIER=1.5       # 安全边际倍数（1.5倍=150股）

# 高级做市配置
MAX_MARKETS=5                      # 最大市场数量（建议3-5个）
MIN_LIQUIDITY=1000                 # 最低流动性要求（美元）
MIN_VOLUME_24H=5000                # 最低24小时交易量（美元）
MAX_SINGLE_ORDER=50                # 单笔订单最大金额（美元）
MIN_ORDER_INTERVAL_MS=3000         # 最小下单间隔（毫秒）
MAX_ORDERS_PER_MARKET=2            # 每个市场最大订单数

# ==================== 🚀 Phase 1: 增强模块配置 ====================

# 启用增强价差计算（Avellaneda-Stoikov 模型）
MM_ENHANCED_SPREAD_ENABLED=true    # 启用AS模型增强的价差计算

# AS模型权重 (0-1, 默认0.5)
# 0 = 完全使用现有系统
# 0.5 = 现有系统和AS模型各占50%（推荐）
# 1 = 完全使用AS模型
MM_AS_MODEL_WEIGHT=0.5

# AS模型参数（通常使用默认值即可，无需修改）
MM_AS_GAMMA=0.1                   # 风险厌恶系数（越高越保守）
MM_AS_LAMBDA=1.0                  # 订单到达速率（每秒订单数）
MM_AS_KAPPA=1.5                   # 价格弹性系数
MM_AS_ALPHA=0.5                   # 库存对价差的影响权重
MM_AS_BETA=0.3                    # 波动率对价差的影响权重
MM_AS_DELTA=0.2                   # 订单流对价差的影响权重

# 库存分类阈值（默认值通常合适）
MM_INVENTORY_SAFE_THRESHOLD=0.3      # 30%以下为安全状态
MM_INVENTORY_WARNING_THRESHOLD=0.5   # 30-50%为警告状态
MM_INVENTORY_DANGER_THRESHOLD=0.7    # 50-70%为危险状态

# 说明：
# - SAFE (<30%): 正常做市，1x价差
# - WARNING (30-50%): 谨慎挂单，1.2x价差，0.8x订单大小
# - DANGER (50-70%): 减少挂单，1.5x价差，0.5x订单大小
# - CRITICAL (>70%): 暂停挂单，强制平仓，2x价差

# ==================== 🛡️ 对冲配置（预测市场库存风险管理）====================

# 启用成交后自动对冲（推荐用于预测市场）
# 说明：当库存变化超过阈值时，自动执行对冲交易
HEDGE_ON_FILL=false                  # 默认关闭，根据需要启用

# 对冲模式
# FLATTEN = 在同一平台平仓对冲（推荐，简单有效）
# CROSS = 跨平台对冲（需要配置跨平台功能）
# NONE = 不对冲
HEDGE_MODE=FLATTEN

# 对冲触发阈值（股数变化超过此值时触发对冲）
# 说明：当库存变化超过此股数时，触发自动对冲
HEDGE_TRIGGER_SHARES=30              # 默认30股，建议20-50

# 对冲最大滑点（基点，250 = 2.5%）
# 说明：对冲订单允许的最大滑点，防止成交价格过差
HEDGE_MAX_SLIPPAGE_BPS=250           # 默认250bps (2.5%)

# 启用部分成交对冲（库存变化较小时也进行部分对冲）
# 说明：当库存变化小于完全对冲阈值，但大于部分对冲阈值时，执行部分对冲
MM_PARTIAL_FILL_HEDGE=false          # 默认关闭

# 部分对冲最大股数
# 说明：部分对冲时，最多对冲的股数
MM_PARTIAL_FILL_HEDGE_MAX_SHARES=15  # 默认15股

# 部分对冲滑点（基点，300 = 3%）
# 说明：部分对冲允许的最大滑点（通常比完全对冲稍大）
MM_PARTIAL_FILL_HEDGE_SLIPPAGE_BPS=300  # 默认300bps (3%)

# WebSocket实时数据（强烈推荐）
PREDICT_WS_ENABLED=true            # 启用WebSocket实时数据

# 日志配置
LOG_LEVEL=info                     # 日志级别：debug, info, warn, error

# 模拟模式（测试时使用）⚠️ 强烈建议先测试！
SIMULATION_MODE=true               # false=实盘, true=模拟

# ==================== 📖 使用说明 ====================

# 1. 复制配置文件
# cp .env.example .env

# 2. 填写必填项（API_KEY, JWT_TOKEN, PRIVATE_KEY, PREDICT_ACCOUNT_ADDRESS）

# 3. 安装依赖并启动
# npm install
# npm start

# ==================== 🎯 功能说明 ====================

本版本提供：
- ✅ 自动做市商挂单
- ✅ 智能报价
- ✅ 风险控制
- ✅ WebSocket实时数据
- ✅ 积分赚取优化

本版本不包含：
- ❌ 套利机器人
- ❌ 高频交易
- ❌ 跨平台套利

# ==================== 💡 新手推荐配置 ====================

# 小资金安全测试（强烈推荐）
MM_ENABLED=true
ORDER_SIZE=25                      # ⚠️ 至少$20确保满足100股要求
MAX_POSITION=50
MAX_DAILY_LOSS=50
SPREAD=0.015                       # 1.5%价差
MAX_SPREAD=0.055                   # 最大5.5%（<6¢积分限制）
MM_POINTS_MIN_SHARES=100           # 积分要求
MM_POINTS_MAX_SPREAD_CENTS=6       # 积分价差限制
MM_POINTS_OPTIMIZATION=true        # 启用积分优化
SIMULATION_MODE=true               # ⚠️ 先模拟测试！

# ==================== ⚠️ 重要提示 ====================

# 1. 永远不要将私钥提交到Git仓库
# 2. 建议先使用 SIMULATION_MODE=true 测试
# 3. 设置合理的止损和限额
# 4. 定期查看交易记录
# 5. 不要使用全部资金进行交易

