# ============================================
# Predict.fun Market Maker Lite - 配置文件
# ============================================
# 只包含代码中实际使用的参数
# 版本: 2.2.1
# 更新: 2026-04-20
# ============================================

# ==================== 必填配置 ====================

# === Predict.fun 平台 ===
API_KEY=                          # Predict.fun API Key
PRIVATE_KEY=                      # 私钥（不带0x前缀，64位hex）
PREDICT_ACCOUNT_ADDRESS=          # 账户地址（0x开头的42位地址）
API_BASE_URL=https://api.predict.fun
RPC_URL=https://bsc-dataseed.binance.org

# === Polymarket 平台 ===
# 当 MM_VENUE=polymarket 时必填
POLYMARKET_PRIVATE_KEY=           # Polymarket 私钥
POLYMARKET_FUNDER_ADDRESS=        # Polymarket Funder 地址
POLYMARKET_SIGNATURE_TYPE=0       # 0=EOA, 1=Magic
POLYMARKET_CHAIN_ID=137           # Polygon 主网
POLYMARKET_AUTO_DERIVE_API_KEY=***

# ==================== 平台选择 ====================

MM_VENUE=predict                  # predict 或 polymarket

# ==================== 交易控制 ====================

# ⚠️ 安全开关：true=只模拟不下单, false=实盘交易
ENABLE_TRADING=false

# ==================== 做市核心参数 ====================

ORDER_SIZE=25                     # 每笔挂单金额（USD），建议 >= 20
MAX_POSITION=100                  # 最大持仓（USD）
MAX_DAILY_LOSS=200                # 每日最大亏损保护（USD）
SPREAD=0.015                      # 基础价差 1.5%
MIN_SPREAD=0.008                  # 最小价差
MAX_SPREAD=0.055                  # 最大价差（Predict积分要求<=6c）

# 做市模式: conservative=保守(第4档), aggressive=激进(第3档)
MM_TRADING_MODE=conservative

# ==================== WebSocket ====================

PREDICT_WS_ENABLED=true           # 启用WebSocket实时数据

# ==================== 积分优化 ====================

MM_POINTS_MIN_SHARES=100          # 最小订单股数（Predict积分要求）
MM_POINTS_MAX_SPREAD_CENTS=6      # 最大价差（美分，Predict积分要求）
MM_POINTS_OPTIMIZATION=true       # 启用积分优化器
MM_POINTS_V2_OPTIMIZER=true       # V2优化器
MM_POINTS_PRIORITIZE=true         # 优先积分市场
MM_POINTS_MIN_ONLY=true           # 只做满足积分要求的市场
MM_POINTS_MIN_MULTIPLIER=1.5      # 安全边际倍数

# ==================== 统一做市商策略 ====================

UNIFIED_MARKET_MAKER_ENABLED=true
UNIFIED_MARKET_MAKER_DUAL_TRACK_MODE=true      # YES+NO同时挂单
UNIFIED_MARKET_MAKER_DYNAMIC_OFFSET_MODE=true  # 动态档位挂单
UNIFIED_MARKET_MAKER_MONITOR_TIER_ONE=true     # 档位监控自动撤单重挂

# ==================== 下单间隔 ====================

MIN_ORDER_INTERVAL_MS=3000        # 最小下单间隔（毫秒）

# ==================== Polymarket 奖励做市风控 ====================
# 以下为保守实盘基线，一般不用改

POLYMARKET_REWARD_REQUIRE_ENABLED=true
POLYMARKET_REWARD_REQUIRE_FIT=true
POLYMARKET_REWARD_MIN_FIT_SCORE=0.6
POLYMARKET_REWARD_MIN_EFFICIENCY=0.0015
POLYMARKET_REWARD_MIN_NET_EFFICIENCY=0.0008
POLYMARKET_REWARD_NET_COST_BPS_MULTIPLIER=1
POLYMARKET_REWARD_MAX_QUEUE_MULTIPLE=12
POLYMARKET_REWARD_MIN_QUEUE_HOURS=0.75
POLYMARKET_REWARD_TARGET_QUEUE_HOURS=1.5
POLYMARKET_REWARD_TARGET_QUEUE_TOLERANCE=0.5
POLYMARKET_REWARD_TARGET_PENALTY_MAX=6
POLYMARKET_OBSERVED_QUEUE_MIN_SAMPLES=3
POLYMARKET_OBSERVED_QUEUE_MAX_WEIGHT=0.65
POLYMARKET_HOUR_RISK_LOOKBACK_DAYS=7
POLYMARKET_HOUR_RISK_PENALTY_MAX=8
POLYMARKET_HOUR_RISK_BLOCK_PENALTY=6
POLYMARKET_REWARD_FAST_FLOW_PENALTY_MAX=8
POLYMARKET_REWARD_FAST_FLOW_RETREAT_MAX_BPS=8
POLYMARKET_REWARD_TARGET_RETREAT_MAX_BPS=6
POLYMARKET_REWARD_TARGET_SIZE_FACTOR_MIN=0.65
POLYMARKET_REWARD_SIZE_CAP_MULTIPLIER=1.25
POLYMARKET_REWARD_CROWDING_PENALTY_START=3
POLYMARKET_REWARD_CROWDING_PENALTY_MAX=12
POLYMARKET_RECENT_RISK_BLOCK_PENALTY=12
POLYMARKET_RECENT_RISK_SIZE_FACTOR_MIN=0.45
POLYMARKET_REWARD_NET_SIZE_FACTOR_MIN=0.5
POLYMARKET_HOUR_RISK_SIZE_FACTOR_MIN=0.55
POLYMARKET_EVENT_RISK_PENALTY_WITHIN_MS=14400000
POLYMARKET_EVENT_RISK_BLOCK_WITHIN_MS=1800000
POLYMARKET_EVENT_RISK_PENALTY_MAX=6
POLYMARKET_EVENT_RISK_SIZE_FACTOR_MIN=0.45
POLYMARKET_EVENT_RISK_RETREAT_MAX_BPS=10
POLYMARKET_CATALYST_RISK_PENALTY_WITHIN_MS=5400000
POLYMARKET_CATALYST_RISK_BLOCK_WITHIN_MS=600000
POLYMARKET_CATALYST_RISK_PENALTY_MAX=7
POLYMARKET_CATALYST_RISK_SIZE_FACTOR_MIN=0.35
POLYMARKET_CATALYST_RISK_RETREAT_MAX_BPS=14
POLYMARKET_GROUP_MAX_EXPOSURE_FACTOR=1.4
POLYMARKET_GROUP_SOFT_EXPOSURE_START=0.7
POLYMARKET_GROUP_SIZE_FACTOR_MIN=0.55
POLYMARKET_GROUP_RETREAT_MAX_BPS=12
POLYMARKET_THEME_MAX_EXPOSURE_FACTOR=2.2
POLYMARKET_THEME_SOFT_EXPOSURE_START=0.65
POLYMARKET_THEME_SIZE_FACTOR_MIN=0.5
POLYMARKET_THEME_RETREAT_MAX_BPS=10
POLYMARKET_ORDER_LIFECYCLE_WINDOW_MS=21600000
POLYMARKET_CANCEL_RATE_PENALTY_START=0.8
POLYMARKET_CANCEL_RATE_PENALTY_MAX=6
POLYMARKET_MIN_AVG_ORDER_LIFETIME_MS=120000
POLYMARKET_SHORT_LIFETIME_PENALTY_MAX=5
POLYMARKET_CANCEL_REASON_DOMINANCE_THRESHOLD=0.45
POLYMARKET_CANCEL_REASON_RETREAT_MAX_BPS=10
POLYMARKET_CANCEL_REASON_SIZE_FACTOR_MIN=0.55
POLYMARKET_STATE_PROBE_SIZE_FACTOR=0.55
POLYMARKET_STATE_PROBE_RETREAT_BPS=3
POLYMARKET_STATE_OBSERVE_SIZE_FACTOR=0.3
POLYMARKET_STATE_OBSERVE_RETREAT_BPS=10
POLYMARKET_STATE_DEFEND_SIZE_FACTOR=0.5
POLYMARKET_STATE_DEFEND_RETREAT_BPS=7
POLYMARKET_CANCEL_PATTERN_FUSE_MIN_COUNT=6
POLYMARKET_CANCEL_PATTERN_FUSE_DOMINANCE=0.7
POLYMARKET_CANCEL_PATTERN_FUSE_PAUSE_MS=1200000
POLYMARKET_PATTERN_MEMORY_ALPHA=0.35
POLYMARKET_PATTERN_MEMORY_MAX_PENALTY=8
POLYMARKET_PATTERN_MEMORY_BLOCK_PENALTY=6
POLYMARKET_PATTERN_MEMORY_TTL_MS=604800000
POLYMARKET_PATTERN_MEMORY_RETREAT_MAX_BPS=8
POLYMARKET_PATTERN_MEMORY_SIZE_FACTOR_MIN=0.7

# Polymarket 逆向选择/成交风控
POLYMARKET_ADVERSE_PRESSURE_THRESHOLD=0.18
POLYMARKET_ADVERSE_IMBALANCE_THRESHOLD=0.55
POLYMARKET_ADVERSE_DEPTH_SPEED_BPS=12
POLYMARKET_POST_ONLY_MIN_HIT_RATE=0.55
POLYMARKET_POST_ONLY_MIN_ATTEMPTS=8
POLYMARKET_POST_ONLY_WINDOW_MS=1800000
POLYMARKET_POST_ONLY_PAUSE_MS=1800000
POLYMARKET_REWARD_PAUSE_MS=1800000
POLYMARKET_POSITION_LOSS_LIMIT_ABS=25
POLYMARKET_POSITION_LOSS_LIMIT_RATIO=0.3
POLYMARKET_POSITION_LOSS_PAUSE_MS=1800000
POLYMARKET_ADVERSE_FILL_WINDOW_MS=1200000
POLYMARKET_ADVERSE_FILL_PAUSE_MS=2700000
POLYMARKET_ADVERSE_FILL_SCORE_THRESHOLD=3.5
POLYMARKET_ADVERSE_FILL_PNL_PENALTY=1.25

# ==================== 市场推荐 ====================

INTERACTIVE_MARKET_SELECTION=false
MARKET_RECOMMEND_TOP_N=20
POLYMARKET_MAX_MARKETS=120

# ==================== 使用说明 ====================
#
# 1. cp .env.example .env
# 2. 填写必填项（API_KEY, PRIVATE_KEY, PREDICT_ACCOUNT_ADDRESS）
# 3. 设置 ENABLE_TRADING=true 开启实盘（默认false=模拟）
# 4. npm install && npm run start:mm
#
# ⚠️ 安全提示：
# - 先用 ENABLE_TRADING=false 测试
# - 永远不要把私钥提交到Git
# - 不要使用全部资金
